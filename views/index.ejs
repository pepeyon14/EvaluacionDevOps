<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/css/styles.css" />
</head>
<body>
  <%- include('partials/navbar') %>

  <main class="container">
    <section class="card">
      <h1>CampusFlow IA</h1>

      <p>
        Plataforma cloud para organizar, administrar y realizar seguimiento de actividades
        universitarias, incorporando automatización DevOps y asistencia mediante Inteligencia
        Artificial.
      </p>

      <div class="actions">
        <% if (user) { %>
          <a href="/dashboard" class="btn">Ir al panel principal</a>
        <% } else { %>
          <a href="/login" class="btn">Iniciar sesión</a>
          <a href="/register" class="btn btn-secondary">Registrarse</a>
        <% } %>
      </div>
    </section>
  </main>
</body>
</html>